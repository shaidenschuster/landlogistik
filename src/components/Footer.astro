---
const currentYear = new Date().getFullYear();
---

<footer class="footer-dark" aria-label="Seitenfooter">
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" aria-label="Landlogistik – Startseite" class="inline-block mb-4">
          <img
            src="/images/logo-schwarz.png"
            alt="Landlogistik"
            width="180"
            height="45"
            class="h-8 w-auto"
            style="filter: brightness(0) invert(1);"
          />
        </a>
        <p class="text-sm leading-relaxed max-w-xs mb-6">
          Ihr Kurierdienst aus Dornbirn für ganz Vorarlberg – schnell, regional, zuverlässig.
          70&nbsp;% E-Flotte. Ab&nbsp;€15 pro Stopp.
        </p>
        <!-- Social -->
        <div class="flex gap-3" aria-label="Social Media">
          <a
            href="https://www.facebook.com/landlogistik"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 flex items-center justify-center rounded-lg bg-white/10 hover:bg-white/20 transition-colors"
            aria-label="Landlogistik auf Facebook"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/landlogistik"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 flex items-center justify-center rounded-lg bg-white/10 hover:bg-white/20 transition-colors"
            aria-label="Landlogistik auf Instagram"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Leistungen -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Leistungen</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/#leistungen">Paketlieferung</a></li>
          <li><a href="/#leistungen">Palettentransport</a></li>
          <li><a href="/#leistungen">Dokumententransport</a></li>
          <li><a href="/#leistungen">Interne Firmenlogistik</a></li>
          <li><a href="/#preise">Preise</a></li>
        </ul>
      </div>

      <!-- Kontakt -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Kontakt</h3>
        <address class="not-italic text-sm space-y-2">
          <p>Kahr Customize GmbH</p>
          <p>Bobletten 23<br />6850 Dornbirn</p>
          <p>
            <a href="tel:+436644620803" class="hover:text-white">0664 46 208 03</a>
          </p>
          <p>
            <a href="mailto:office@landlogistik.at" class="hover:text-white">office@landlogistik.at</a>
          </p>
          <p class="pt-1 text-xs text-white/50">Mo–Fr 08:00–12:00, 13:00–16:00</p>
        </address>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="container py-5 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-white/40">
      <p>© {currentYear} Landlogistik – Ihr Kurierdienst aus Dornbirn für ganz Vorarlberg.</p>
      <nav aria-label="Rechtliches" class="flex gap-4">
        <a href="/impressum/" class="hover:text-white/70">Impressum</a>
        <a href="/datenschutz/" class="hover:text-white/70">Datenschutz</a>
        <a href="/agb/" class="hover:text-white/70">AGB</a>
      </nav>
    </div>
  </div>
</footer>
