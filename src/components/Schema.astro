---
interface Breadcrumb {
  name: string;
  url: string;
}

interface Props {
  breadcrumbs?: Breadcrumb[];
  type?: 'WebPage' | 'ContactPage' | 'FAQPage';
  faqs?: { question: string; answer: string }[];
}

const { breadcrumbs, type = 'WebPage', faqs } = Astro.props;

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://landlogistik.at/#business',
  name: 'Landlogistik',
  legalName: 'Kahr Customize GmbH',
  url: 'https://landlogistik.at/',
  telephone: '+436644620803',
  email: 'office@landlogistik.at',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Bobletten 23',
    addressLocality: 'Dornbirn',
    postalCode: '6850',
    addressCountry: 'AT',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 47.4143,
    longitude: 9.7437,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '12:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '13:00',
      closes: '16:00',
    },
  ],
  areaServed: {
    '@type': 'State',
    name: 'Vorarlberg',
    '@id': 'https://www.wikidata.org/wiki/Q688',
  },
  description:
    'Kurierdienst für Vorarlberg – Pakete, Paletten, Dokumente und interne Firmenlogistik. 70 % E-Flotte. Ab €15 pro Stopp.',
  priceRange: '€€',
};

const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://landlogistik.at/#website',
  url: 'https://landlogistik.at/',
  name: 'Landlogistik',
  inLanguage: 'de-AT',
};

const organization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://landlogistik.at/#org',
  name: 'Landlogistik',
  legalName: 'Kahr Customize GmbH',
  url: 'https://landlogistik.at/',
  logo: 'https://landlogistik.at/images/logo.png',
  sameAs: [
    'https://www.facebook.com/landlogistik',
    'https://www.instagram.com/landlogistik',
  ],
};

const breadcrumbSchema = breadcrumbs
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        item: b.url,
      })),
    }
  : null;

const faqSchema =
  faqs && faqs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.map((f) => ({
          '@type': 'Question',
          name: f.question,
          acceptedAnswer: { '@type': 'Answer', text: f.answer },
        })),
      }
    : null;
---

<script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
<script type="application/ld+json" set:html={JSON.stringify(website)} />
<script type="application/ld+json" set:html={JSON.stringify(organization)} />
{breadcrumbSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}
{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}
