---
const nav = [
  { label: 'Leistungen', href: '/#leistungen' },
  { label: 'Preise', href: '/#preise' },
  { label: 'Ablauf', href: '/#ablauf' },
  { label: 'Über uns', href: '/#ueber-uns' },
  { label: 'FAQ', href: '/#faq' },
  { label: 'Kontakt', href: '/kontakt/' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent"
  aria-label="Hauptnavigation"
>
  <div class="container">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center focus-visible:outline-white"
        aria-label="Landlogistik – Startseite"
      >
        <img
          id="site-logo"
          src="/images/logo-schwarz.png"
          alt="Landlogistik"
          width="180"
          height="45"
          class="h-9 w-auto transition-all duration-300"
          style="filter: brightness(0) invert(1);"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Hauptmenü">
        {nav.map((item) => (
          <a
            href={item.href}
            class="px-3 py-2 rounded-md text-sm font-medium text-white/90 hover:text-white hover:bg-white/10 transition-colors duration-150 nav-link"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Phone + CTA desktop -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href="tel:+436644620803"
          class="phone-link flex items-center gap-2 text-sm font-semibold text-white hover:opacity-80 transition-all"
          aria-label="Jetzt anrufen: 0664 46 208 03"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 .92h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
          0664 46 208 03
        </a>
        <a
          href="/kontakt/"
          class="px-5 py-2.5 bg-white text-primary font-semibold text-sm rounded-lg hover:bg-warm transition-colors shadow-sm"
        >
          Angebot anfragen
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="nav-toggle"
        class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 text-white"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="block w-6 h-0.5 bg-current transition-all duration-200 hamburger-line-1"></span>
        <span class="block w-6 h-0.5 bg-current transition-all duration-200 hamburger-line-2"></span>
        <span class="block w-6 h-0.5 bg-current transition-all duration-200 hamburger-line-3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-dark border-t border-white/10"
    aria-label="Mobilmenü"
  >
    <nav class="container py-4 flex flex-col gap-1">
      {nav.map((item) => (
        <a
          href={item.href}
          class="px-4 py-3 rounded-lg text-white/90 hover:text-white hover:bg-white/10 font-medium transition-colors mobile-nav-link"
        >
          {item.label}
        </a>
      ))}
      <div class="mt-4 pt-4 border-t border-white/10 flex flex-col gap-3">
        <a
          href="tel:+436644620803"
          class="flex items-center gap-2 px-4 py-3 text-white font-semibold"
          aria-label="Anrufen: 0664 46 208 03"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 .92h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
          0664 46 208 03
        </a>
        <a
          href="/kontakt/"
          class="mx-4 px-5 py-3 bg-primary text-white font-semibold text-center rounded-lg hover:bg-primary-dark transition-colors"
        >
          Angebot anfragen
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header') as HTMLElement;
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLElement;

  const logo = document.getElementById('site-logo') as HTMLImageElement;
  const navLinks = header.querySelectorAll<HTMLAnchorElement>('.nav-link');

  function updateHeader() {
    const scrolled = window.scrollY > 60;
    header.classList.toggle('bg-transparent', !scrolled);
    header.classList.toggle('shadow-md', scrolled);
    if (scrolled) {
      header.style.backgroundColor = '#ffffff';
      logo.style.filter = 'none';
      navLinks.forEach(l => { l.style.color = '#111111'; });
      const phone = header.querySelector<HTMLAnchorElement>('.phone-link');
      if (phone) phone.style.color = '#111111';
    } else {
      header.style.backgroundColor = '';
      logo.style.filter = 'brightness(0) invert(1)';
      navLinks.forEach(l => { l.style.color = ''; });
      const phone = header.querySelector<HTMLAnchorElement>('.phone-link');
      if (phone) phone.style.color = '';
    }
  }
  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  // Mobile toggle
  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Menü öffnen' : 'Menü schließen');
  });

  // Close mobile menu on nav link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    });
  });
</script>
